BOT_TOKEN=your_telegram_bot_token
FACEIT_API_KEY=your_faceit_data_api_key

# Optional — default is bot_data.db in the project folder.
# Droplet + docker-compose: compose sets DB_PATH=/data/bot_data.db + Docker volume.
# App Platform: no persistent disk — DB is ephemeral unless you use a managed DB later.

# Optional observability (see DEPLOY.md)
# LOG_UPDATES=0
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0

# Optional FACEIT circuit breaker (see DEPLOY.md)
# FACEIT_CIRCUIT_FAILURE_THRESHOLD=4
# FACEIT_CIRCUIT_OPEN_SEC=60
